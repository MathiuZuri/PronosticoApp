@using Microsoft.AspNetCore.Components.Forms

@* Agregamos position: relative para contener el input transparente *@
<div class="sigepp-upload-zone rz-p-4" style="position: relative; cursor: pointer; overflow: hidden;">
    
    @* TRUCO UX: El input real está aquí, pero es invisible y cubre todo el cuadro *@
    <InputFile OnChange="@OnInternalChange" accept=".csv, .xlsx, .xls" 
               style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer; z-index: 2;" />
    
    @* Todo el contenido visual va detrás del input transparente *@
    <div style="position: relative; z-index: 1; pointer-events: none;">
        <RadzenIcon Icon="cloud_upload" Style="font-size: 2.5rem; color: var(--sigepp-primary);" />
        
        <RadzenText TextStyle="TextStyle.Subtitle2" Class="rz-mt-2" Style="font-weight: 600;">
            @Label
        </RadzenText>
        
        @if (string.IsNullOrEmpty(currentFileName))
        {
            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--sigepp-text-muted); display: block; margin-top: 4px;">
                Arrastra o haz clic aquí (.csv, .xlsx)
            </RadzenText>
        }
        else
        {
            <RadzenText TextStyle="TextStyle.Caption" Class="rz-mt-2 rz-color-success" Style="display: block; font-weight: 600;">
                <RadzenIcon Icon="check_circle" Style="vertical-align: middle; font-size: 1.1rem; margin-right: 4px;" /> 
                @currentFileName
            </RadzenText>
        }
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = "Cargar Archivo";
    
    // Este evento notificará al padre cuando el archivo esté listo en RAM
    [Parameter] public EventCallback<(byte[] Bytes, string Name)> OnFileProcessed { get; set; }

    private string currentFileName = "";

    private async Task OnInternalChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        currentFileName = file.Name;

        using var stream = file.OpenReadStream(maxAllowedSize: 10485760);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        
        // Enviamos los datos al componente padre
        await OnFileProcessed.InvokeAsync((ms.ToArray(), file.Name));
    }
}