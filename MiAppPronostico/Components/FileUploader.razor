@using Microsoft.AspNetCore.Components.Forms

<div class="sigepp-upload-zone rz-p-4">
    <RadzenIcon Icon="cloud_upload" Style="font-size: 2.5rem; color: var(--sigepp-primary);" />
    <RadzenText TextStyle="TextStyle.Subtitle2" Class="rz-mt-2">@Label</RadzenText>
    <InputFile OnChange="@OnInternalChange" accept=".csv, .xlsx, .xls" class="rz-mt-2" />
    
    @if (!string.IsNullOrEmpty(currentFileName))
    {
        <RadzenText TextStyle="TextStyle.Caption" Class="rz-mt-2 rz-color-success">
            <RadzenIcon Icon="check_circle" Style="vertical-align: middle; font-size: 1rem;" /> @currentFileName
        </RadzenText>
    }
</div>

@code {
    [Parameter] public string Label { get; set; } = "Cargar Archivo";
    
    // Este evento notificará al padre cuando el archivo esté listo en RAM
    [Parameter] public EventCallback<(byte[] Bytes, string Name)> OnFileProcessed { get; set; }

    private string currentFileName = "";

    private async Task OnInternalChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        currentFileName = file.Name;

        using var stream = file.OpenReadStream(maxAllowedSize: 10485760);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        
        // Enviamos los datos al componente padre
        await OnFileProcessed.InvokeAsync((ms.ToArray(), file.Name));
    }
}